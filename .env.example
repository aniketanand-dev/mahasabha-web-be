NODE_ENV=development
PORT=5000
MONGODB_URL=mongodb://127.0.0.1:27017/mahasabha
JWT_SECRET=change-this-to-a-strong-secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=mahasabha-backend
JWT_AUDIENCE=mahasabha-admin
BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15
FRONTEND_URL=http://localhost:4200
FRONTEND_ORIGINS=http://localhost:4200,http://127.0.0.1:5500
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
UPLOAD_RATE_LIMIT_MAX_REQUESTS=30
TRUST_PROXY=1
GALLERY_DATA_FILE=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mahasabha.local
